# =============================================================
# UNSU 플랫폼 (Root) 프로덕션 배포용 환경변수 템플릿 (.env.production)
# =============================================================
# 이 파일을 복사하여 .env.production 파일로 이름을 바꾸고 실제 비밀 값을 채워 넣으십시오.
# Vite로 빌드되는 프론트오피스(fo) 및 백오피스(bo)에서 참조합니다.

# 1. API 주소 연동
# 프로덕션 배포 서버 주소로 변경하여 빌드하십시오.
VITE_API_URL="https://unsu-api.onrender.com"

# 2. LangChain Tracing (관제 옵저버빌리티)
LANGCHAIN_API_KEY="lsv2_pt_..."
LANGCHAIN_PROJECT="unsu-platform-shared-session-2026"
LANGCHAIN_TRACING_V2=true

# 3. 외부 API Keys (공공데이터포털 및 기타 연동 키)
ITS_API_KEY=""
KORAIL_API_KEY=""
SEOUL_SUBWAY_API_KEY=""
METRO_API_KEY=""
AIRPORT_API_KEY=""
RESTROOM_API_KEY=""
OPINET_API_KEY=""
KOPIS_API_KEY=""
DATA_GO_KR_API_KEY=""
SEOUL_OPEN_API_KEY=""
GYEONGGI_API_KEY=""
TOUR_API_KEY=""
CODEF_API_KEY=""

# 4. 데이터베이스 연결 정보
# Supabase DB Connection String (URI 형식)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# 5. Gemini API Key
GEMINI_API_KEY=""

# 6. 보안 시크릿 키 (32바이트 이상 강력한 문자열)
SECRET_KEY=""
