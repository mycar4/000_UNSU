# =============================================================
# UNSU 백엔드 API (api) 프로덕션 배포용 환경변수 템플릿
# =============================================================
# 이 파일을 복사하여 api/.env 파일로 이름을 바꾸고 실제 프로덕션 서버에 설정하십시오.

# 1. 서버 포트
PORT=3001

# 2. 클라우드 데이터베이스 (Supabase PostgreSQL URI)
# Supabase Dashboard -> Settings -> Database -> Connection string -> URI
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# 3. 인공지능 API 연동 (Google AI Studio)
GEMINI_API_KEY="AIzaSy..."

# 4. 개인정보(PII) 암복호화 시크릿 키
# 랜덤한 32바이트(256비트) 문자열. 프로덕션 환경에서는 반드시 강력한 난수로 생성할 것.
SECRET_KEY="unsu_platform_enterprise_secret_key_v1"

# 5. LangChain Tracing (관제 옵저버빌리티)
LANGCHAIN_API_KEY="lsv2_pt_..."
LANGCHAIN_PROJECT="unsu-platform-shared-session-2026"
LANGCHAIN_TRACING_V2=true
