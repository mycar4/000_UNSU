{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": false,
    "exactOptionalPropertyTypes": false,
    "verbatimModuleSyntax": false,
    "outDir": "./dist"
  },
  "include": ["src/**/*"]
}
